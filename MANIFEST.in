# MANIFEST.in — 控制 sdist 源码包打包内容

# 映射规则（核心数据文件，缺失则所有 compat 调用失败）
recursive-include py2wl/compat/mappings *.yaml

# 项目说明文件
include README.md
include LICENSE
include pyproject.toml
include MANIFEST.in

# 排除开发/临时文件
exclude *.bak
recursive-exclude * *.bak
recursive-exclude * *.py[cod]
recursive-exclude * __pycache__
recursive-exclude .git *
exclude perf_compare*.py
exclude generate_*.py
exclude demo.py
exclude DemoHardKernel.py
exclude rule_editor.py
exclude release.py
